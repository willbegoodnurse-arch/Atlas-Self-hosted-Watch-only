# Atlas environment template
# Copy to .env and edit for your machine.
# Never commit the real .env file.
# Do not put seed phrases, private keys, WIF keys, xprv values, real xpubs, or RPC passwords here.

# App
APP_NAME=Atlas
NODE_ENV=production
WEB_PORT=3010
API_HOST=0.0.0.0
API_PORT=3011

# Authentication and sessions
# Use a long random value for real deployments.
SESSION_SECRET=replace_with_a_long_random_session_secret
SESSION_TTL_HOURS=12

# Initial admin setup happens in the web UI. This placeholder is for operator notes only.
ADMIN_USER=admin

# Comma-separated list of frontend origins allowed by API CORS.
# Development web server: http://localhost:3000
# Docker web port: http://localhost:3010
WEB_ORIGIN=http://localhost:3000,http://localhost:3010

# false for local HTTP development.
# true when the app is served behind HTTPS.
COOKIE_SECURE=false

# Auto-lock vault after N minutes of inactivity. 0 disables auto-lock.
VAULT_AUTO_LOCK_MINUTES=30

# Frontend
# The browser uses this URL to reach the API.
NEXT_PUBLIC_API_URL=http://localhost:3011

# Backend data
# Default is apps/api/data. Override only if you know where encrypted data should live.
# DATA_DIR=/absolute/path/to/watch-wallet-data

# Backend mode
# Current normal operation uses a mempool-compatible HTTP API.
# Fulcrum variables below are used for diagnostics; balance/UTXO/tx lookups use MEMPOOL_API_URL.
API_MODE=mempool

# Mempool-compatible API
# Public APIs are convenient but reduce privacy because address lookups leave your server.
# Prefer a local mempool instance when possible.
# Examples:
# MEMPOOL_API_URL=https://mempool.space/api
# MEMPOOL_API_URL=https://blockstream.info/api
# MEMPOOL_API_URL=http://127.0.0.1:8080/api
# MEMPOOL_API_URL=http://192.168.1.20:8080/api
# MEMPOOL_API_URL=http://100.x.y.z:8080/api
MEMPOOL_API_URL=http://localhost:8080/api

# Optional Fulcrum / Electrum diagnostics
# Leave FULCRUM_HOST empty to disable diagnostics.
FULCRUM_HOST=
FULCRUM_PORT=50001
FULCRUM_TLS_PORT=50002
FULCRUM_USE_TLS=false

# Display defaults returned by safe runtime settings
DEFAULT_NETWORK=mainnet
DEFAULT_CURRENCY=KRW
DEFAULT_UNIT=BTC
