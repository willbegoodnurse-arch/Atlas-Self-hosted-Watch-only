# watch-wallet — environment configuration template
# Copy to .env and fill in your values before starting the server.
# Never commit the real .env to version control.

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=watch wallet
NODE_ENV=production
WEB_PORT=3010
API_PORT=3011

# ── Auth ─────────────────────────────────────────────────────────────────────
SESSION_SECRET=change_this_to_a_long_random_string
ADMIN_USER=admin
# Comma-separated list of allowed origins for CORS
WEB_ORIGIN=http://localhost:3000,http://localhost:3010
COOKIE_SECURE=false
SESSION_TTL_HOURS=12

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3011

# ── Backend mode ─────────────────────────────────────────────────────────────
# API_MODE selects the active backend source:
#   mempool  — use a mempool-compatible HTTP API (public or local instance)
#   fulcrum  — reserved for future Fulcrum/ElectrumX full-node support
API_MODE=mempool

# ── Mempool API URL ───────────────────────────────────────────────────────────
# Public APIs (convenient, but exposes your xpub to a third party):
#   MEMPOOL_API_URL=https://mempool.space/api
#   MEMPOOL_API_URL=https://blockstream.info/api
#
# Local mempool instance (recommended for privacy):
#   MEMPOOL_API_URL=http://127.0.0.1:8080/api
#   MEMPOOL_API_URL=http://192.168.x.x:8080/api
#
# Tailscale / CGNAT:
#   MEMPOOL_API_URL=http://100.x.y.z:8080/api
MEMPOOL_API_URL=http://localhost:8080/api

# ── Fulcrum / ElectrumX (optional) ───────────────────────────────────────────
# Set FULCRUM_HOST to enable Fulcrum connectivity diagnostics.
# Leave empty or unset to disable. Full Fulcrum backend support (balance/tx
# queries via Electrum protocol) will be added in a future phase.
FULCRUM_HOST=127.0.0.1
FULCRUM_PORT=50001
FULCRUM_TLS_PORT=50002
FULCRUM_USE_TLS=false

# ── Network & display defaults ────────────────────────────────────────────────
DEFAULT_NETWORK=mainnet
DEFAULT_CURRENCY=KRW
DEFAULT_UNIT=BTC
